TELEGRAM_BOT_TOKEN=your-spin24star-bot-token-from-botfather
# One id, or several comma-/space-separated ids for multiple master admins:
# MASTER_ADMIN_ID=111111111,222222222
MASTER_ADMIN_ID=your-telegram-user-id

# Recommended for this site: spin24star's register endpoint is guarded by an
# AWS WAF CAPTCHA (see CLAUDE.md). Without a key, WAF-blocked signups are just
# reported as a clean failure.
CAPSOLVER_API_KEY=

# signup | gameplay | all -- which command set this instance exposes.
# spin24star has no casino support wired up (supports_casino=False), so this
# instance runs signups only.
BOT_MODE=signup
BOT_SITE_URL=https://spin24star.com
ADMINS_FILE=admins.spin24star.json
SETTINGS_FILE=bot_settings.spin24star.json
