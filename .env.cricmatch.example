TELEGRAM_BOT_TOKEN=your-cricmatch-bot-token-from-botfather
# One id, or several comma-/space-separated ids for multiple master admins:
# MASTER_ADMIN_ID=111111111,222222222
MASTER_ADMIN_ID=your-telegram-user-id

# Optional: CapSolver API key (https://capsolver.com). Not needed here --
# cricmatch247 doesn't WAF-CAPTCHA its register endpoint.
CAPSOLVER_API_KEY=

BOT_SITE_URL=https://cricmatch247.com?btag=211079
ADMINS_FILE=admins.cricmatch.json
SETTINGS_FILE=bot_settings.cricmatch.json
# Optional: where hedge-betting account pairs are stored (gitignored, holds
# plaintext passwords). Give each bot instance its own file, like the two above.
PAIRS_FILE=pairs.cricmatch.json
# Optional: per-run hedge history for /runs and /runlog (gitignored; usernames
# + balances, no passwords). Give each instance its own file, like the above.
PAIR_RUNS_FILE=pair_runs.cricmatch.json
