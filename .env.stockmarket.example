# Cricmatch STOCK MARKET bot: the paired-hedge commands (/pair, /pairs,
# /delpair, /run, /stoprun, /runs, /runlog) driving Evolution's "Stock Market
# Live" instead of Baccarat -- acc1 bets UP, acc2 bets DOWN on the same round,
# and BOTH positions are cashed out together each round. No signup commands,
# and no /testbaccarat (that one is Baccarat-specific and stays on the
# gameplay bot).
#
# Why a separate bot rather than a flag on /run: the game is fixed per
# instance, exactly like BOT_SITE_URL fixes the site, so /run needs no extra
# argument and there's only one run_cmd implementation to keep correct.
TELEGRAM_BOT_TOKEN=your-stockmarket-bot-token-from-botfather
# One id, or several comma-/space-separated ids for multiple master admins:
# MASTER_ADMIN_ID=111111111,222222222
MASTER_ADMIN_ID=your-telegram-user-id

BOT_MODE=stockmarket
BOT_SITE_URL=https://cricmatch247.com?btag=211079
ADMINS_FILE=admins.stockmarket.json
SETTINGS_FILE=bot_settings.stockmarket.json
# Pair credentials + run history. MUST be distinct from every other instance's
# files -- each process reads them once at import and rewrites them whole on
# every save, so two bots sharing a path silently clobber each other.
# (pairs.* holds plaintext passwords; both patterns are gitignored.)
PAIRS_FILE=pairs.stockmarket.json
PAIR_RUNS_FILE=pair_runs.stockmarket.json

# How many /run hedge sessions may execute at once (each drives two Chromium
# browsers). Default 3.
# MAX_CONCURRENT_RUNS=3

# NOTE on sizing: Stock Market Live's table minimum is 10 rupees, versus
# Baccarat A's 100 -- so a live smoke test here costs a tenth as much. Start
# with "/run <pair> 10 1" before scaling either the amount or the rounds.
