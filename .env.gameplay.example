# Cricmatch GAMEPLAY bot: only the casino/hedge commands (/testbaccarat,
# /pair, /pairs, /delpair, /run, /stoprun, /runs, /runlog) plus proxy and
# admin management. No signup commands -- those live on the signup bots.
TELEGRAM_BOT_TOKEN=your-gameplay-bot-token-from-botfather
# One id, or several comma-/space-separated ids for multiple master admins:
# MASTER_ADMIN_ID=111111111,222222222
MASTER_ADMIN_ID=your-telegram-user-id

BOT_MODE=gameplay
BOT_SITE_URL=https://cricmatch247.com?btag=211079
ADMINS_FILE=admins.gameplay.json
SETTINGS_FILE=bot_settings.gameplay.json
# Pair credentials + run history (both gitignored; pairs holds plaintext
# passwords). If gameplay moved here from a combined cricmatch bot, point
# these at that bot's existing files to keep the pair/run history.
PAIRS_FILE=pairs.gameplay.json
PAIR_RUNS_FILE=pair_runs.gameplay.json

# How many /run hedge sessions may execute at once (each drives two Chromium
# browsers). Default 3.
# MAX_CONCURRENT_RUNS=3
