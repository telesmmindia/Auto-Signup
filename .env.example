TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# One id, or several comma-/space-separated ids for multiple master admins:
# MASTER_ADMIN_ID=111111111,222222222
MASTER_ADMIN_ID=your-telegram-user-id

# Optional: CapSolver API key (https://capsolver.com) to auto-solve the AWS WAF
# CAPTCHA that guards spin24star's register endpoint. Leave blank/unset to
# disable -- a WAF-blocked signup is then just reported as a clean failure.
CAPSOLVER_API_KEY=

# Optional: locks this bot process to one site (falls back to main.py's
# SITE_URL if unset). Only needed if you're running one bot per site --
# see "Running one bot per site" in telegram_bot.py's module docstring.
# BOT_SITE_URL=https://cricmatch247.com?btag=211079

# Optional: only needed when running more than one bot instance out of the
# same directory, so each process persists admins/proxy/url to its own file
# instead of racing on the shared admins.json / bot_settings.json defaults.
# ADMINS_FILE=admins.cricmatch.json
# SETTINGS_FILE=bot_settings.cricmatch.json

# Optional: how many signups this bot instance can run at the same time.
# Each unit is its own Chromium process, so raising this is real parallelism,
# not just faster polling. Default 1 (old serialized behavior). Only raise
# this if you have that many distinct proxies/IPs to spread the load across --
# more concurrency from one IP just means more requests/sec against the
# target site's WAF, which is how cricmatch's 403 rate-block gets tripped.
# BOT_CONCURRENCY=3

# Optional: how many /run paired-hedge runs (different pairs) can be active
# at once. Each one launches TWO of its own temporary Chromium browsers
# (Banker + Player), so this is real parallel load, same caveat as
# BOT_CONCURRENCY above -- size it to your proxy/IP diversity and box
# resources. Default 3.
# MAX_CONCURRENT_RUNS=3
