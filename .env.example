TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
MASTER_ADMIN_ID=your-telegram-user-id

# Optional: CapSolver API key (https://capsolver.com) to auto-solve the AWS WAF
# CAPTCHA that guards spin24star's register endpoint. Leave blank/unset to
# disable -- a WAF-blocked signup is then just reported as a clean failure.
CAPSOLVER_API_KEY=
