TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
MASTER_ADMIN_ID=your-telegram-user-id

# Optional: CapSolver API key (https://capsolver.com) to auto-solve the AWS WAF
# CAPTCHA that guards spin24star's register endpoint. Leave blank/unset to
# disable -- a WAF-blocked signup is then just reported as a clean failure.
CAPSOLVER_API_KEY=

# Optional: locks this bot process to one site (falls back to main.py's
# SITE_URL if unset). Only needed if you're running one bot per site --
# see "Running one bot per site" in telegram_bot.py's module docstring.
# BOT_SITE_URL=https://cricmatch247.com?btag=211079

# Optional: only needed when running more than one bot instance out of the
# same directory, so each process persists admins/proxy/url to its own file
# instead of racing on the shared admins.json / bot_settings.json defaults.
# ADMINS_FILE=admins.cricmatch.json
# SETTINGS_FILE=bot_settings.cricmatch.json
